{
  "name": "cle-demo-notes",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.0.5+sha512.94fa09e72016402aefce788e46994e18eb1922998b16b6fd5aa6bafd8ae4dea05d0852f60247fdb7d5ab8199a7b0beda830398f3f80cb9f822398522a1535481",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "test": "pnpm --filter @cle/api run test",
    "db:migrate": "pnpm --filter @cle/api exec prisma migrate deploy && pnpm --filter @cle/api exec prisma generate",
    "db:reset": "pnpm --filter @cle/api exec prisma migrate reset --force",
    "db:seed": "pnpm --filter @cle/api run seed"
  }
}
