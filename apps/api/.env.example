# API
NODE_ENV=development
PORT=3000

# Used to sign session cookies. Pick a long random string in production.
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# SQLite file location (relative to apps/api). Prisma reads DATABASE_URL.
DATABASE_URL="file:./dev.db"

# Where uploaded attachments are written. Relative paths are resolved from apps/api.
UPLOAD_DIR=../../uploads
MAX_UPLOAD_BYTES=5242880

# Seed script picks these up to create the admin user.
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=adminpass123
